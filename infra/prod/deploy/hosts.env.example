# Copia in hosts.env e compila con gli IP reali dei nodi.
# Privati per il cluster, pubblici per SSH da questo PC.
SSH_USER=utente_ssh

# worker-1: Citus coordinator + Mongo config server/mongos
COORD_PUB=ip_pubblico_worker-1
COORD_PRIV=10.0.1.8

# VM-1: driver di carico + generatore + metriche
DRIVER_PUB=ip_pubblico_vm-1
DRIVER_PRIV=10.0.1.4

# VM-2/3/4: Citus worker / Mongo shard — "IP_pubblico IP_privato" per riga
WORKERS=(
  "ip_pubblico_vm-2 10.0.1.5"
  "ip_pubblico_vm-3 10.0.1.7"
  "ip_pubblico_vm-4 10.0.1.6"
)